name: Generate Quotex Signals

on:
  workflow_dispatch:
    inputs:
      asset_name:
        description: 'Asset'
        required: true
        default: 'USDBRL_OTC'

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
    - name: Checkout Code
      uses: actions/checkout@v3

    - name: Set up Python
      uses: actions/setup-python@v4
      with:
        python-version: '3.10'

    - name: Install Dependencies
      run: |
        python -m pip install --upgrade pip setuptools wheel
        pip install pandas pandas-ta --no-cache-dir
        pip install git+https://github.com/nand0n/quotexapi.git --no-cache-dir || pip install quotexapi --no-cache-dir

    - name: Run Backtest
      env:
        QUOTEX_EMAIL: ${{ secrets.MY_EMAIL }}
        QUOTEX_PASS: ${{ secrets.MY_PASS }}
        ASSET: ${{ github.event.inputs.asset_name }}
      run: |
        python script.py

    - name: Upload Signals File
      uses: actions/upload-artifact@v4
      with:
        name: quotex-signals-file
        path: all_perfect_signals.txt
